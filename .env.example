# -----------------------------------------------------------------------------
# Local development — SPA on http://localhost:5173 (Vite default)
# -----------------------------------------------------------------------------
VITE_API_BASE_URL=http://localhost:4000

# Note: PORT in this file is NOT used by Vite unless you wire it in vite.config.ts.
# Container port 3008 is set in docker/nginx.conf + Dockerfile EXPOSE.

# -----------------------------------------------------------------------------
# Production (`vite build`) — use committed `.env.production` (Docker does not copy `.env`)
# -----------------------------------------------------------------------------
# Copy this block into `.env.production` in the repo root (loaded automatically by Vite in production).
# Must be https:// if users open the UI over HTTPS. Must match API_PUBLIC_URL on the server.
# VITE_API_BASE_URL=https://api.example.com
